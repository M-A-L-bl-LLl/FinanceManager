<Window x:Class="FinanceManager.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:FinanceManager.UI.ViewModels"
        xmlns:views="clr-namespace:FinanceManager.UI.Views"
        mc:Ignorable="d"
        Title="Finance Manager" Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        WindowStyle="None"
        AllowsTransparency="True">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TransactionsViewModel}">
            <views:TransactionsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CategoriesViewModel}">
            <views:CategoriesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BudgetsViewModel}">
            <views:BudgetsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

        <!-- Nav button style -->
        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Height" Value="52" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="20,0" />
            <Setter Property="Margin" Value="8,2" />
            <Setter Property="Foreground" Value="#B0BEC5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="materialDesign:RippleAssist.Feedback" Value="#FFFFFF20" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="Background" Value="#FFFFFF15" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== SIDEBAR ===== -->
            <Grid Grid.Column="0">
                <Grid.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1A1A2E" Offset="0" />
                        <GradientStop Color="#16213E" Offset="1" />
                    </LinearGradientBrush>
                </Grid.Background>

                <DockPanel>
                    <!-- Logo -->
                    <StackPanel DockPanel.Dock="Top" Margin="24,32,24,28">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#7C4DFF" Offset="0" />
                                        <GradientStop Color="#448AFF" Offset="1" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="CurrencyUsd" Foreground="White"
                                                         Width="20" Height="20"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center" />
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Finance" Foreground="White"
                                           FontSize="18" FontWeight="Bold" LineHeight="20" />
                                <TextBlock Text="Manager" FontSize="18" FontWeight="Bold" LineHeight="20">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#7C4DFF" Offset="0" />
                                            <GradientStop Color="#448AFF" Offset="1" />
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Section label -->
                    <TextBlock DockPanel.Dock="Top" Text="МЕНЮ"
                               Foreground="#546E7A" FontSize="10" FontWeight="Bold"
                               Margin="28,0,0,8" />

                    <!-- Nav items -->
                    <StackPanel DockPanel.Dock="Top">
                        <Button Command="{Binding NavigateToDashboardCommand}"
                                Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboardOutline"
                                                         Width="22" Height="22"
                                                         Margin="0,0,14,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Дашборд" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToTransactionsCommand}"
                                Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="SwapHorizontalBold"
                                                         Width="22" Height="22"
                                                         Margin="0,0,14,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Транзакции" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToCategoriesCommand}"
                                Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="TagMultipleOutline"
                                                         Width="22" Height="22"
                                                         Margin="0,0,14,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Категории" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToBudgetsCommand}"
                                Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="WalletOutline"
                                                         Width="22" Height="22"
                                                         Margin="0,0,14,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Бюджеты" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToSettingsCommand}"
                                Style="{StaticResource NavButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CogOutline"
                                                         Width="22" Height="22"
                                                         Margin="0,0,14,0"
                                                         VerticalAlignment="Center" />
                                <TextBlock Text="Настройки" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Bottom: version -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="24,0,24,20">
                        <Separator Background="#FFFFFF15" Margin="0,0,0,16" />
                        <TextBlock Text="v1.0.0" Foreground="#37474F"
                                   FontSize="11" HorizontalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Grid>

            <!-- ===== MAIN AREA ===== -->
            <materialDesign:DialogHost Grid.Column="1" Identifier="RootDialog" DialogTheme="Inherit">
            <Grid Background="{DynamicResource MaterialDesign.Brush.Background}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="64" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Topbar -->
                <Border Grid.Row="0" Background="{DynamicResource MaterialDesign.Brush.CardBackground}"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.TextFieldBoxHoverBackground}" BorderThickness="0,0,0,1">
                    <Grid Margin="24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentPageTitle}"
                                       FontSize="20" FontWeight="SemiBold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Window controls -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Click="MinimizeButton_Click" ToolTip="Свернуть">
                                <materialDesign:PackIcon Kind="WindowMinimize" Width="16" Height="16" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Click="MaximizeButton_Click" ToolTip="Развернуть">
                                <materialDesign:PackIcon Kind="WindowMaximize" Width="16" Height="16" />
                            </Button>
                            <Button Style="{StaticResource MaterialDesignIconButton}"
                                    Foreground="#F44336"
                                    Click="CloseButton_Click" ToolTip="Закрыть">
                                <materialDesign:PackIcon Kind="WindowClose" Width="16" Height="16" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Page content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ContentControl Content="{Binding CurrentViewModel}" Margin="24" />
                </ScrollViewer>
            </Grid>
            </materialDesign:DialogHost>
        </Grid>
    </Border>
</Window>
