<UserControl x:Class="FinanceManager.UI.Views.TransactionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:FinanceManager.UI.Converters">

    <UserControl.Resources>
        <converters:HexToColorBrushConverter x:Key="HexToBrush" />
        <converters:StringToPackIconKindConverter x:Key="StringToIconKind" />
    </UserControl.Resources>

    <StackPanel>

        <!-- Filter bar -->
        <materialDesign:Card Padding="20" UniformCornerRadius="12" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="1.5*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <DatePicker Grid.Column="0"
                            materialDesign:HintAssist.Hint="Дата от"
                            SelectedDate="{Binding FilterFrom}"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                <DatePicker Grid.Column="2"
                            materialDesign:HintAssist.Hint="Дата до"
                            SelectedDate="{Binding FilterTo}"
                            Style="{StaticResource MaterialDesignOutlinedDatePicker}" />

                <ComboBox Grid.Column="4"
                          materialDesign:HintAssist.Hint="Категория"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding FilterCategory}"
                          DisplayMemberPath="Name"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}" />

                <TextBox Grid.Column="6"
                         materialDesign:HintAssist.Hint="Поиск по комментарию"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}" />

                <Button Grid.Column="8"
                        Command="{Binding ApplyFiltersCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#7C4DFF" BorderBrush="#7C4DFF"
                        Height="40" Padding="16,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterOutline" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Применить" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="10"
                        Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="40" Padding="12,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterRemoveOutline" Width="16" Height="16"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Сбросить" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- Toolbar: count + add button -->
        <Grid Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock FontSize="14" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" VerticalAlignment="Center">
                    <Run Text="Транзакций: " />
                    <Run Text="{Binding Transactions.Count, Mode=OneWay}" FontWeight="SemiBold" />
                </TextBlock>
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Command="{Binding ExportToExcelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Height="40" Padding="14,0" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="MicrosoftExcel" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"
                                                 Foreground="#4CAF50" />
                        <TextBlock Text="Экспорт в Excel" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding AddTransactionCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#7C4DFF" BorderBrush="#7C4DFF"
                        Height="40" Padding="16,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"
                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="Добавить транзакцию" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <materialDesign:Card UniformCornerRadius="12">
            <DataGrid ItemsSource="{Binding Transactions}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      HorizontalGridLinesBrush="#F0F0F0"
                      Background="{DynamicResource MaterialDesign.Brush.CardBackground}"
                      RowHeight="52"
                      BorderThickness="0"
                      materialDesign:DataGridAssist.ColumnHeaderPadding="16,12"
                      materialDesign:DataGridAssist.CellPadding="16,0">

                <DataGrid.Columns>

                    <!-- Date -->
                    <DataGridTextColumn Header="Дата"
                                        Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}"
                                        Width="110" />

                    <!-- Category -->
                    <DataGridTemplateColumn Header="Категория" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="30" Height="30" CornerRadius="8" Margin="0,0,10,0"
                                            Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}}">
                                        <materialDesign:PackIcon Width="16" Height="16" Foreground="White"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Kind="{Binding CategoryIcon, Converter={StaticResource StringToIconKind}}" />
                                    </Border>
                                    <TextBlock Text="{Binding CategoryName}" VerticalAlignment="Center"
                                               FontSize="13" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Type badge -->
                    <DataGridTemplateColumn Header="Тип" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="6" Padding="8,4"
                                        Background="{Binding TypeBadgeBackground, Converter={StaticResource HexToBrush}}"
                                        HorizontalAlignment="Left" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding TypeLabel}" FontSize="12" FontWeight="Medium"
                                               Foreground="{Binding AmountColor, Converter={StaticResource HexToBrush}}" />
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Amount -->
                    <DataGridTemplateColumn Header="Сумма" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FormattedAmount}" VerticalAlignment="Center"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="{Binding AmountColor, Converter={StaticResource HexToBrush}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Comment -->
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}"
                                        Width="*" />

                    <!-- Actions -->
                    <DataGridTemplateColumn Header="" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Command="{Binding DataContext.EditTransactionCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Редактировать"
                                            Foreground="#7C4DFF" Width="32" Height="32">
                                        <materialDesign:PackIcon Kind="PencilOutline" Width="16" Height="16" />
                                    </Button>
                                    <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                            Command="{Binding DataContext.DeleteTransactionCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="Удалить"
                                            Foreground="#F44336" Width="32" Height="32">
                                        <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16" />
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>

                <!-- Empty state -->
                <DataGrid.Style>
                    <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Transactions.Count}" Value="0">
                                <Setter Property="Background" Value="White" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Style>
            </DataGrid>
        </materialDesign:Card>

        <!-- Empty state overlay -->
        <materialDesign:Card UniformCornerRadius="12" Margin="0,-1,0,0">
            <materialDesign:Card.Style>
                <Style TargetType="materialDesign:Card">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Transactions.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </materialDesign:Card.Style>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0,48,0,48">
                <materialDesign:PackIcon Kind="SwapHorizontalBold" Width="56" Height="56"
                                         Foreground="#CFD8DC" HorizontalAlignment="Center" />
                <TextBlock Text="Транзакций не найдено" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" HorizontalAlignment="Center" Margin="0,16,0,8" />
                <TextBlock Text="Добавьте первую транзакцию или измените фильтры"
                           Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" FontSize="14" HorizontalAlignment="Center" />
            </StackPanel>
        </materialDesign:Card>

    </StackPanel>
</UserControl>
