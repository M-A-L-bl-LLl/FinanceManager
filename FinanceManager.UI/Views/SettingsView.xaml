<UserControl x:Class="FinanceManager.UI.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <StackPanel MaxWidth="560" HorizontalAlignment="Left">

        <!-- Appearance -->
        <materialDesign:Card Padding="24" UniformCornerRadius="12" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#7C4DFF" Offset="0" />
                                <GradientStop Color="#448AFF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <materialDesign:PackIcon Kind="PaletteOutline" Foreground="White"
                                                 Width="20" Height="20"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Внешний вид" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                        <TextBlock Text="Настройки темы приложения" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    </StackPanel>
                </StackPanel>

                <Separator Margin="0,0,0,20"
                           Background="{DynamicResource MaterialDesign.Brush.CardBackground}" />

                <!-- Dark mode toggle -->
                <Grid>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Тёмная тема" FontSize="14" FontWeight="Medium"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                        <TextBlock FontSize="12" Margin="0,2,0,0"
                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Светлая тема активна" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDarkTheme}" Value="True">
                                            <Setter Property="Text" Value="Тёмная тема активна" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                    <ToggleButton HorizontalAlignment="Right" VerticalAlignment="Center"
                                  IsChecked="{Binding IsDarkTheme}"
                                  Style="{StaticResource MaterialDesignSwitchToggleButton}" />
                </Grid>
            </StackPanel>
        </materialDesign:Card>

        <!-- Data -->
        <materialDesign:Card Padding="24" UniformCornerRadius="12" Margin="0,0,0,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#00BCD4" Offset="0" />
                                <GradientStop Color="#009688" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <materialDesign:PackIcon Kind="DatabaseOutline" Foreground="White"
                                                 Width="20" Height="20"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Данные" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                        <TextBlock Text="Резервное копирование и восстановление" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    </StackPanel>
                </StackPanel>

                <Separator Margin="0,0,0,20"
                           Background="{DynamicResource MaterialDesign.Brush.CardBackground}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding ExportDatabaseCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Stretch" Height="44">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseExportOutline" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Экспорт" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Command="{Binding ImportDatabaseCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            HorizontalAlignment="Stretch" Height="44">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseImportOutline" Width="18" Height="18"
                                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="Импорт" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </materialDesign:Card>

        <!-- About -->
        <materialDesign:Card Padding="24" UniformCornerRadius="12">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0"
                            Background="#E8F5E9">
                        <materialDesign:PackIcon Kind="InformationOutline" Foreground="#4CAF50"
                                                 Width="20" Height="20"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="О приложении" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                        <TextBlock Text="Версия и технологии" FontSize="12"
                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    </StackPanel>
                </StackPanel>

                <Separator Margin="0,0,0,20"
                           Background="{DynamicResource MaterialDesign.Brush.CardBackground}" />

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Версия" FontSize="13"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <TextBlock Text="1.0.0" HorizontalAlignment="Right" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                </Grid>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Фреймворк" FontSize="13"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <TextBlock Text=".NET 8 WPF" HorizontalAlignment="Right" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                </Grid>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="MVVM" FontSize="13"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <TextBlock Text="CommunityToolkit.Mvvm" HorizontalAlignment="Right" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                </Grid>
                <Grid>
                    <TextBlock Text="База данных" FontSize="13"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    <TextBlock Text="SQLite + EF Core 8" HorizontalAlignment="Right" FontSize="13" FontWeight="Medium"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                </Grid>
            </StackPanel>
        </materialDesign:Card>

    </StackPanel>
</UserControl>
