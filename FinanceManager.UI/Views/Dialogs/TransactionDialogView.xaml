<UserControl x:Class="FinanceManager.UI.Views.Dialogs.TransactionDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:FinanceManager.UI.Converters">

    <UserControl.Resources>
        <converters:HexToColorBrushConverter x:Key="HexToBrush" />
    </UserControl.Resources>

    <Grid Width="420">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,20,24,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7C4DFF" Offset="0" />
                    <GradientStop Color="#448AFF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="SwapHorizontalBold" Foreground="White"
                                         Width="24" Height="24" VerticalAlignment="Center"
                                         Margin="0,0,12,0" />
                <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold"
                           VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Добавить транзакцию" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Text" Value="Редактировать транзакцию" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel Grid.Row="1" Margin="24,20,24,8">

            <!-- Type toggle -->
            <TextBlock Text="Тип" FontSize="12" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" Margin="0,0,0,8" />
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton Grid.Column="0" Content="Расход" IsChecked="{Binding IsExpense}"
                             Style="{StaticResource MaterialDesignOutlinedButton}"
                             Foreground="#F44336" BorderBrush="#F44336"
                             HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                             Height="40" />
                <RadioButton Grid.Column="2" Content="Доход" IsChecked="{Binding IsIncome}"
                             Style="{StaticResource MaterialDesignOutlinedButton}"
                             Foreground="#4CAF50" BorderBrush="#4CAF50"
                             HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                             Height="40" />
            </Grid>

            <!-- Amount -->
            <TextBox materialDesign:HintAssist.Hint="Сумма (₽)"
                     Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,16" />

            <!-- Date -->
            <DatePicker materialDesign:HintAssist.Hint="Дата"
                        SelectedDate="{Binding Date, ValidatesOnDataErrors=True}"
                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                        Margin="0,0,0,16" />

            <!-- Category -->
            <ComboBox materialDesign:HintAssist.Hint="Категория"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory, ValidatesOnDataErrors=True}"
                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                      Margin="0,0,0,16">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="24" Height="24" CornerRadius="6" Margin="0,0,10,0"
                                    Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                                <materialDesign:PackIcon Width="14" Height="14" Foreground="White"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Kind" Value="Wallet" />
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                            </Border>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <!-- Comment -->
            <TextBox materialDesign:HintAssist.Hint="Комментарий (необязательно)"
                     Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,4" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="16,4,16,16">
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Null}"
                    Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" Margin="0,0,8,0" Content="ОТМЕНА" />
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="SaveButton_Click"
                    Background="#7C4DFF" BorderBrush="#7C4DFF" Content="СОХРАНИТЬ" />
        </StackPanel>
    </Grid>
</UserControl>
