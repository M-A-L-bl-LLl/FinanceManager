<UserControl x:Class="FinanceManager.UI.Views.Dialogs.MessageDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:FinanceManager.UI.Converters">

    <UserControl.Resources>
        <converters:HexToColorBrushConverter x:Key="HexToBrush" />
        <converters:StringToPackIconKindConverter x:Key="StringToIconKind" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <StackPanel Width="360" Margin="32,28,32,24">

        <!-- Icon -->
        <Grid Width="64" Height="64" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Ellipse Fill="{Binding IconColor, Converter={StaticResource HexToBrush}}"
                     Opacity="0.15" />
            <materialDesign:PackIcon Width="32" Height="32"
                                     Foreground="{Binding IconColor, Converter={StaticResource HexToBrush}}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"
                                     Kind="{Binding Icon, Converter={StaticResource StringToIconKind}}" />
        </Grid>

        <!-- Title -->
        <TextBlock Text="{Binding Title}"
                   FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
                   Margin="0,0,0,10" />

        <!-- Message -->
        <TextBlock Text="{Binding Message}"
                   FontSize="13"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   LineHeight="20"
                   HorizontalAlignment="Center"
                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                   Margin="0,0,0,28" />

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Null}"
                    Visibility="{Binding ShowCancel, Converter={StaticResource BoolToVis}}"
                    MinWidth="100" Height="40" Margin="0,0,12,0"
                    Content="{Binding CancelText}" />
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="true"
                    Background="{Binding IconColor, Converter={StaticResource HexToBrush}}"
                    BorderBrush="{Binding IconColor, Converter={StaticResource HexToBrush}}"
                    MinWidth="100" Height="40"
                    Content="{Binding ConfirmText}" />
        </StackPanel>

    </StackPanel>
</UserControl>
