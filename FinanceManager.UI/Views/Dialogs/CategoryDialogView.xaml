<UserControl x:Class="FinanceManager.UI.Views.Dialogs.CategoryDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:FinanceManager.UI.Converters">

    <UserControl.Resources>
        <converters:HexToColorBrushConverter x:Key="HexToBrush" />
        <converters:StringToPackIconKindConverter x:Key="StringToIconKind" />
    </UserControl.Resources>

    <Grid Width="480">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header with live preview -->
        <Border Grid.Row="0" Padding="24,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7C4DFF" Offset="0" />
                    <GradientStop Color="#448AFF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <Border Width="52" Height="52" CornerRadius="14" Margin="0,0,16,0"
                        Background="{Binding SelectedColor, Converter={StaticResource HexToBrush}}">
                    <materialDesign:PackIcon Width="28" Height="28" Foreground="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Kind="{Binding SelectedIcon, Converter={StaticResource StringToIconKind}}" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Foreground="White" FontSize="18" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Новая категория" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                        <Setter Property="Text" Value="Редактировать категорию" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding Name}" Foreground="#FFFFFF99" FontSize="13" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel Grid.Row="1" Margin="24,20,24,8">

            <!-- Name -->
            <TextBox materialDesign:HintAssist.Hint="Название категории"
                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Margin="0,0,0,16" />

            <!-- Type -->
            <TextBlock Text="Тип" FontSize="12" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" Margin="0,0,0,8" />
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton Grid.Column="0" Content="Расход" IsChecked="{Binding IsExpense}"
                             Style="{StaticResource MaterialDesignOutlinedButton}"
                             Foreground="#F44336" BorderBrush="#F44336"
                             HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                             Height="40" />
                <RadioButton Grid.Column="2" Content="Доход" IsChecked="{Binding IsIncome}"
                             Style="{StaticResource MaterialDesignOutlinedButton}"
                             Foreground="#4CAF50" BorderBrush="#4CAF50"
                             HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                             Height="40" />
            </Grid>

            <!-- Color picker -->
            <TextBlock Text="Цвет" FontSize="12" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" Margin="0,0,0,8" />
            <ListBox ItemsSource="{Binding AvailableColors}"
                     SelectedItem="{Binding SelectedColor}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     BorderThickness="0" Background="Transparent"
                     Margin="0,0,0,16">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="3" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Grid Width="32" Height="32">
                                        <Border CornerRadius="16"
                                                Background="{Binding Converter={StaticResource HexToBrush}}" />
                                        <materialDesign:PackIcon x:Name="Check" Kind="Check"
                                                                 Width="16" Height="16"
                                                                 Foreground="White"
                                                                 HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"
                                                                 Visibility="Collapsed" />
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <!-- Icon picker -->
            <TextBlock Text="Иконка" FontSize="12" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" Margin="0,0,0,8" />
            <Border BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="8" Padding="4"
                    MaxHeight="140">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox ItemsSource="{Binding AvailableIcons}"
                             SelectedItem="{Binding SelectedIcon}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             BorderThickness="0" Background="Transparent">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="2" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bg" Width="36" Height="36" CornerRadius="8"
                                                    Background="Transparent">
                                                <materialDesign:PackIcon Width="20" Height="20"
                                                                         Foreground="#607D8B"
                                                                         HorizontalAlignment="Center"
                                                                         VerticalAlignment="Center"
                                                                         Kind="{Binding Converter={StaticResource StringToIconKind}}" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="#EDE7F6" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="16,4,16,16">
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Null}"
                    Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" Margin="0,0,8,0" Content="ОТМЕНА" />
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="SaveButton_Click"
                    Background="#7C4DFF" BorderBrush="#7C4DFF" Content="СОХРАНИТЬ" />
        </StackPanel>
    </Grid>
</UserControl>
