<UserControl x:Class="FinanceManager.UI.Views.Dialogs.BudgetDialogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:FinanceManager.UI.Converters">

    <UserControl.Resources>
        <converters:HexToColorBrushConverter x:Key="HexToBrush" />
        <converters:StringToPackIconKindConverter x:Key="StringToIconKind" />
    </UserControl.Resources>

    <Grid Width="380">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="24,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#7C4DFF" Offset="0" />
                    <GradientStop Color="#448AFF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal">
                <Border Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0"
                        Background="{Binding CategoryColor, Converter={StaticResource HexToBrush}}">
                    <materialDesign:PackIcon Width="24" Height="24" Foreground="White"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Kind="{Binding CategoryIcon, Converter={StaticResource StringToIconKind}}" />
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Установить лимит" Foreground="White"
                               FontSize="17" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CategoryName}" Foreground="#FFFFFF99" FontSize="13" Margin="0,2,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel Grid.Row="1" Margin="24,24,24,8">
            <TextBox materialDesign:HintAssist.Hint="Лимит расходов (₽)"
                     Text="{Binding LimitText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="16,8,16,16">
            <Button Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{x:Static materialDesign:DialogHost.CloseDialogCommand}"
                    CommandParameter="{x:Null}"
                    Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" Margin="0,0,8,0" Content="ОТМЕНА" />
            <Button Style="{StaticResource MaterialDesignRaisedButton}"
                    Click="SaveButton_Click"
                    Background="#7C4DFF" BorderBrush="#7C4DFF" Foreground="White" Content="СОХРАНИТЬ" />
        </StackPanel>
    </Grid>
</UserControl>
