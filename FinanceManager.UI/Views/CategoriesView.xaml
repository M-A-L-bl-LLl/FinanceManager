<UserControl x:Class="FinanceManager.UI.Views.CategoriesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:FinanceManager.UI.Converters">

    <UserControl.Resources>
        <converters:HexToColorBrushConverter x:Key="HexToBrush" />
        <converters:StringToPackIconKindConverter x:Key="StringToIconKind" />

        <!-- Category card data template -->
        <DataTemplate x:Key="CategoryCardTemplate">
            <materialDesign:Card UniformCornerRadius="12" Margin="0,0,12,12" Width="200">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Icon + Name -->
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0"
                                Background="{Binding Color, Converter={StaticResource HexToBrush}}">
                            <materialDesign:PackIcon Width="22" Height="22" Foreground="White"
                                                     HorizontalAlignment="Center" VerticalAlignment="Center"
                                                     Kind="{Binding Icon, Converter={StaticResource StringToIconKind}}" />
                        </Border>
                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" MaxWidth="100" />
                    </StackPanel>

                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Command="{Binding DataContext.EditCategoryCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Foreground="#7C4DFF" Width="32" Height="32" ToolTip="Редактировать">
                            <materialDesign:PackIcon Kind="PencilOutline" Width="16" Height="16" />
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                Command="{Binding DataContext.DeleteCategoryCommand,
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"
                                Foreground="#F44336" Width="32" Height="32" ToolTip="Удалить">
                            <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Height="16" />
                        </Button>
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel>

        <!-- Toolbar -->
        <Grid Margin="0,0,0,20">
            <TextBlock Text="Управление категориями" FontSize="15" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       VerticalAlignment="Center" />
            <Button HorizontalAlignment="Right"
                    Command="{Binding AddCategoryCommand}"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#7C4DFF" BorderBrush="#7C4DFF" Foreground="White"
                    Height="40" Padding="16,0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"
                                             VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBlock Text="Добавить категорию" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Expense categories -->
        <TextBlock Text="РАСХОДЫ" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                   Margin="0,0,0,12" />
        <ItemsControl ItemsSource="{Binding ExpenseCategories}"
                      ItemTemplate="{StaticResource CategoryCardTemplate}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Empty state for expenses -->
        <Border Padding="32" Margin="0,0,0,24">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ExpenseCategories.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="Нет категорий расходов" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       FontSize="14" HorizontalAlignment="Center" />
        </Border>

        <!-- Separator -->
        <Separator Background="#E0E0E0" Margin="0,4,0,20" />

        <!-- Income categories -->
        <TextBlock Text="ДОХОДЫ" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                   Margin="0,0,0,12" />
        <ItemsControl ItemsSource="{Binding IncomeCategories}"
                      ItemTemplate="{StaticResource CategoryCardTemplate}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <!-- Empty state for income -->
        <Border Padding="32">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IncomeCategories.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="Нет категорий доходов" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                       FontSize="14" HorizontalAlignment="Center" />
        </Border>

    </StackPanel>
</UserControl>
