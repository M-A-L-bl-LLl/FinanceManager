<UserControl x:Class="FinanceManager.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <StackPanel>
        <!-- Summary cards -->
        <Grid Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Balance -->
            <materialDesign:Card Grid.Column="0" Padding="24" UniformCornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#7C4DFF" Offset="0" />
                                    <GradientStop Color="#448AFF" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="WalletOutline" Foreground="White"
                                                     Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Баланс" VerticalAlignment="Center"
                                   FontSize="14" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    </StackPanel>
                    <TextBlock Grid.Row="2" Text="{Binding Balance}"
                               FontSize="26" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                </Grid>
            </materialDesign:Card>

            <!-- Income -->
            <materialDesign:Card Grid.Column="2" Padding="24" UniformCornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0" Background="#E8F5E9">
                            <materialDesign:PackIcon Kind="TrendingUp" Foreground="#4CAF50"
                                                     Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Доходы" VerticalAlignment="Center"
                                   FontSize="14" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    </StackPanel>
                    <TextBlock Grid.Row="2" Text="{Binding Income}"
                               FontSize="26" FontWeight="Bold" Foreground="#4CAF50" />
                </Grid>
            </materialDesign:Card>

            <!-- Expenses -->
            <materialDesign:Card Grid.Column="4" Padding="24" UniformCornerRadius="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="12" Margin="0,0,12,0" Background="#FFEBEE">
                            <materialDesign:PackIcon Kind="TrendingDown" Foreground="#F44336"
                                                     Width="22" Height="22"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Расходы" VerticalAlignment="Center"
                                   FontSize="14" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                    </StackPanel>
                    <TextBlock Grid.Row="2" Text="{Binding Expenses}"
                               FontSize="26" FontWeight="Bold" Foreground="#F44336" />
                </Grid>
            </materialDesign:Card>
        </Grid>

        <!-- Charts -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <!-- Line chart -->
            <materialDesign:Card Grid.Column="0" Padding="24" UniformCornerRadius="16" Height="320">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Динамика за 6 месяцев" FontSize="16"
                               FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Margin="0,0,0,8" />

                    <lvc:CartesianChart Grid.Row="1"
                                        Series="{Binding LineSeries}"
                                        XAxes="{Binding XAxes}"
                                        YAxes="{Binding YAxes}"
                                        LegendPosition="Bottom"
                                        TooltipPosition="Top" />
                </Grid>
            </materialDesign:Card>

            <!-- Pie chart -->
            <materialDesign:Card Grid.Column="2" Padding="24" UniformCornerRadius="16" Height="320">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Расходы по категориям" FontSize="16"
                               FontWeight="SemiBold" Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" Margin="0,0,0,8" />

                    <!-- Chart -->
                    <lvc:PieChart Grid.Row="1"
                                  Series="{Binding PieSeries}"
                                  LegendPosition="Bottom"
                                  TooltipPosition="Center">
                        <lvc:PieChart.Style>
                            <Style TargetType="lvc:PieChart">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPieData}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </lvc:PieChart.Style>
                    </lvc:PieChart>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPieData}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <materialDesign:PackIcon Kind="ChartDonut" Width="48" Height="48"
                                                 Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" HorizontalAlignment="Center" />
                        <TextBlock Text="Нет расходов за этот месяц" Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                   Margin="0,8,0,0" HorizontalAlignment="Center" FontSize="13" />
                    </StackPanel>
                </Grid>
            </materialDesign:Card>
        </Grid>
    </StackPanel>
</UserControl>
